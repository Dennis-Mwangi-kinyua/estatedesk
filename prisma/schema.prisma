generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String                @id @default(cuid())
  fullName                String
  phone                   String?               @unique
  email                   String?               @unique
  passwordHash            String
  status                  UserStatus            @default(ACTIVE)
  platformRole            PlatformRole          @default(USER)
  canCreatePlatformAdmins Boolean               @default(false)
  isRootSuperAdmin        Boolean               @default(false)
  emailVerified           DateTime?
  phoneVerified           DateTime?
  twoFactorEnabled        Boolean               @default(false)
  lastLoginAt             DateTime?
  deletedAt               DateTime?
  createdByUserId         String?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt
  username                String?               @unique
  slug                    String?               @unique
  createdApiKeys          ApiKey[]              @relation("CreatedBy")
  uploadedAssets          Asset[]               @relation("AssetUploader")
  auditLogs               AuditLog[]            @relation("AuditActor")
  caretakerAssignments    CaretakerAssignment[] @relation("CaretakerUser")
  inspections             Inspection[]          @relation("InspectionInspector")
  invitedUsers            Invitation[]          @relation("InvitedBy")
  issuesAssigned          IssueTicket[]         @relation("IssueAssignedTo")
  issuesReported          IssueTicket[]         @relation("IssueReportedBy")
  caretakerLeases         Lease[]               @relation("LeaseCaretaker")
  memberships             Membership[]
  meterReadingsApproved   MeterReading[]        @relation("MeterReadingApprovedBy")
  meterReadingsSubmitted  MeterReading[]        @relation("MeterReadingSubmittedBy")
  notifications           Notification[]        @relation("NotificationUser")
  platformPermissions     PlatformPermission[]
  tenant                  Tenant?
  tenantActionLogs        TenantActionLog[]     @relation("TenantActionActor")
  createdBy               User?                 @relation("UserCreatedBy", fields: [createdByUserId], references: [id])
  createdUsers            User[]                @relation("UserCreatedBy")

  @@index([username])
  @@index([email])
  @@index([phone])
  @@index([status])
  @@index([platformRole])
  @@index([deletedAt])
  @@index([createdByUserId])
  @@index([isRootSuperAdmin])
}

model PlatformPermission {
  id         String                 @id @default(cuid())
  userId     String
  permission PlatformPermissionType
  granted    Boolean                @default(true)
  createdAt  DateTime               @default(now())
  updatedAt  DateTime               @updatedAt
  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, permission])
  @@index([userId])
  @@index([permission])
}

model Organization {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  phone                String?
  email                String?
  address              String?
  status               OrganizationStatus    @default(ACTIVE)
  currencyCode         String                @default("KES")
  timezone             String                @default("Africa/Nairobi")
  dataRetentionDays    Int                   @default(2555)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  apiKeys              ApiKey[]
  assets               Asset[]
  auditLogs            AuditLog[]
  caretakerAssignments CaretakerAssignment[]
  invitations          Invitation[]
  issues               IssueTicket[]
  leases               Lease[]
  memberships          Membership[]
  notifications        Notification[]
  settings             OrganizationSettings?
  payments             Payment[]
  properties           Property[]
  rentCharges          RentCharge[]
  subscription         Subscription?
  taxCharges           TaxCharge[]
  tenants              Tenant[]
  tenantActionLogs     TenantActionLog[]
  waterBills           WaterBill[]

  @@index([slug])
  @@index([status])
  @@index([name])
  @@index([deletedAt])
}

model OrganizationSettings {
  id                   String       @id @default(cuid())
  orgId                String       @unique
  branding             Json?
  features             Json?
  customFields         Json?
  notificationDefaults Json?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  org                  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Subscription {
  id                   String                   @id @default(cuid())
  orgId                String                   @unique
  plan                 BillingPlan              @default(FREE)
  status               SubscriptionStatus       @default(ACTIVE)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  cancelAt             DateTime?
  cancelledAt          DateTime?
  trialStartsAt        DateTime?
  trialEndsAt          DateTime?
  mpesaPaybill         String?
  stripeSubscriptionId String?                  @unique
  billingEmail         String?
  metadata             Json?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  org                  Organization             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  planChanges          SubscriptionPlanChange[]

  @@index([plan])
  @@index([status])
  @@index([currentPeriodEnd])
}

model SubscriptionPlanChange {
  id             String       @id @default(cuid())
  subscriptionId String
  fromPlan       BillingPlan?
  toPlan         BillingPlan
  effectiveFrom  DateTime
  effectiveTo    DateTime?
  reason         String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([toPlan])
  @@index([effectiveFrom])
}

model Asset {
  id               String         @id @default(cuid())
  orgId            String
  fileName         String
  fileType         String
  mimeType         String?
  key              String
  size             Int
  metadata         Json?
  assetType        AssetType      @default(GENERIC)
  uploadedByUserId String
  deletedAt        DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  org              Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  uploadedBy       User           @relation("AssetUploader", fields: [uploadedByUserId], references: [id])
  issuePhotos      IssueTicket[]  @relation("IssuePhoto")
  lease            Lease?         @relation("LeaseContract")
  meterReadings    MeterReading[] @relation("MeterPhoto")
  tenant           Tenant?        @relation("TenantProfileImage")

  @@index([orgId])
  @@index([assetType])
  @@index([key])
  @@index([deletedAt])
}

model Membership {
  id        String       @id @default(cuid())
  orgId     String
  userId    String
  role      OrgRole
  scopeType ScopeType    @default(ORG)
  scopeId   String       @default("ORG_SCOPE")
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, role, scopeType, scopeId])
  @@index([orgId])
  @@index([userId])
  @@index([role])
  @@index([scopeType, scopeId])
  @@index([userId, orgId, role])
  @@index([userId, role, createdAt])
}

model Property {
  id                   String                @id @default(cuid())
  orgId                String
  name                 String
  location             String?
  address              String?
  notes                String?
  type                 PropertyType          @default(RESIDENTIAL)
  waterRatePerUnit     Decimal?              @db.Decimal(10, 2)
  waterFixedCharge     Decimal?              @db.Decimal(10, 2)
  isActive             Boolean               @default(true)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  buildings            Building[]
  caretakerAssignments CaretakerAssignment[]
  issues               IssueTicket[]
  org                  Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  taxCharges           TaxCharge[]
  units                Unit[]

  @@unique([orgId, name])
  @@index([orgId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([orgId, deletedAt])
}

model Building {
  id                   String                @id @default(cuid())
  propertyId           String
  name                 String
  notes                String?
  isActive             Boolean               @default(true)
  deletedAt            DateTime?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  property             Property              @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  caretakerAssignments CaretakerAssignment[]
  units                Unit[]

  @@unique([propertyId, name])
  @@index([propertyId])
  @@index([isActive])
  @@index([deletedAt])
}

model Unit {
  id               String            @id @default(cuid())
  propertyId       String
  buildingId       String?
  houseNo          String
  type             UnitType          @default(APARTMENT)
  bedrooms         Int?
  bathrooms        Int?
  floorArea        Float?
  rentAmount       Decimal           @db.Decimal(12, 2)
  depositAmount    Decimal?          @db.Decimal(12, 2)
  status           UnitStatus        @default(VACANT)
  vacantSince      DateTime?
  notes            String?
  isActive         Boolean           @default(true)
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  issues           IssueTicket[]
  leases           Lease[]
  meterReadings    MeterReading[]
  tenantActionLogs TenantActionLog[]
  building         Building?         @relation(fields: [buildingId], references: [id])
  property         Property          @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  waterBills       WaterBill[]

  @@index([propertyId])
  @@index([buildingId])
  @@index([status])
  @@index([isActive])
  @@index([deletedAt])
  @@index([propertyId, isActive, deletedAt, status])
}

model Tenant {
  id               String            @id @default(cuid())
  orgId            String
  userId           String?           @unique
  type             TenantType        @default(INDIVIDUAL)
  fullName         String
  companyName      String?
  kraPin           String?
  phone            String
  email            String?
  nationalId       String?
  status           TenantStatus      @default(ACTIVE)
  notes            String?
  dataConsent      Boolean           @default(false)
  consentUpdatedAt DateTime?
  marketingConsent Boolean           @default(false)
  deletedAt        DateTime?
  profileImageId   String?           @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  archivedAt       DateTime?
  blacklistReason  String?
  blacklistedAt    DateTime?
  leases           Lease[]
  moveOutNotices   MoveOutNotice[]
  nextOfKin        NextOfKin?
  notifications    Notification[]    @relation("NotificationTenant")
  payments         Payment[]
  taxCharges       TaxCharge[]
  org              Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  profileImage     Asset?            @relation("TenantProfileImage", fields: [profileImageId], references: [id])
  user             User?             @relation(fields: [userId], references: [id])
  actionLogs       TenantActionLog[]
  waterBills       WaterBill[]

  @@unique([orgId, phone])
  @@unique([orgId, email])
  @@index([orgId])
  @@index([status])
  @@index([fullName])
  @@index([nationalId])
  @@index([archivedAt])
  @@index([blacklistedAt])
  @@index([deletedAt])
  @@index([orgId, deletedAt, status])
}

model NextOfKin {
  id           String  @id @default(cuid())
  tenantId     String  @unique
  name         String
  relationship String
  phone        String
  email        String?
  tenant       Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Lease {
  id                 String            @id @default(cuid())
  orgId              String
  unitId             String
  tenantId           String
  caretakerUserId    String?
  startDate          DateTime
  endDate            DateTime?
  dueDay             Int               @default(5)
  monthlyRent        Decimal           @db.Decimal(12, 2)
  deposit            Decimal?          @db.Decimal(12, 2)
  status             LeaseStatus       @default(ACTIVE)
  notes              String?
  deletedAt          DateTime?
  contractDocumentId String?           @unique
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  caretaker          User?             @relation("LeaseCaretaker", fields: [caretakerUserId], references: [id])
  contractDocument   Asset?            @relation("LeaseContract", fields: [contractDocumentId], references: [id])
  org                Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit               Unit              @relation(fields: [unitId], references: [id], onDelete: Cascade)
  moveOutNotices     MoveOutNotice[]
  rentCharges        RentCharge[]
  taxCharges         TaxCharge[]
  tenantActionLogs   TenantActionLog[]

  @@index([orgId])
  @@index([unitId])
  @@index([tenantId])
  @@index([caretakerUserId])
  @@index([status, unitId])
  @@index([status, tenantId])
  @@index([startDate])
  @@index([endDate])
  @@index([deletedAt])
  @@index([orgId, status, deletedAt])
}

model CaretakerAssignment {
  id              String       @id @default(cuid())
  orgId           String
  caretakerUserId String
  propertyId      String?
  buildingId      String?
  isPrimary       Boolean      @default(true)
  active          Boolean      @default(true)
  assignedAt      DateTime     @default(now())
  endedAt         DateTime?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  building        Building?    @relation(fields: [buildingId], references: [id], onDelete: Cascade)
  caretaker       User         @relation("CaretakerUser", fields: [caretakerUserId], references: [id], onDelete: Cascade)
  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property        Property?    @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([caretakerUserId])
  @@index([propertyId])
  @@index([buildingId])
  @@index([active])
  @@index([caretakerUserId, active, propertyId])
  @@index([caretakerUserId, active, buildingId])
}

model RentCharge {
  id          String       @id @default(cuid())
  orgId       String
  leaseId     String
  period      String
  amountDue   Decimal      @db.Decimal(12, 2)
  dueDate     DateTime
  amountPaid  Decimal      @default(0) @db.Decimal(12, 2)
  balance     Decimal      @db.Decimal(12, 2)
  status      ChargeStatus @default(UNPAID)
  chargeType  ChargeType   @default(RENT)
  description String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  payments    Payment[]    @relation("PaymentToRentCharge")
  lease       Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([leaseId, period, chargeType])
  @@index([orgId])
  @@index([leaseId, status])
  @@index([period, status])
  @@index([dueDate])
  @@index([chargeType])
  @@index([orgId, status, dueDate])
}

model MeterReading {
  id                String        @id @default(cuid())
  unitId            String
  period            String
  prevReading       Int
  currentReading    Int
  unitsUsed         Int
  status            ReadingStatus @default(SUBMITTED)
  submittedByUserId String
  approvedByUserId  String?
  approvedAt        DateTime?
  rejectionReason   String?
  notes             String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  photoAssetId      String?
  approvedBy        User?         @relation("MeterReadingApprovedBy", fields: [approvedByUserId], references: [id])
  photoAsset        Asset?        @relation("MeterPhoto", fields: [photoAssetId], references: [id])
  submittedBy       User          @relation("MeterReadingSubmittedBy", fields: [submittedByUserId], references: [id])
  unit              Unit          @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, period])
  @@index([unitId, status])
  @@index([period, status])
  @@index([submittedByUserId, createdAt])
  @@index([status, createdAt])
}

model WaterBill {
  id          String       @id @default(cuid())
  orgId       String
  unitId      String
  tenantId    String
  period      String
  unitsUsed   Int
  ratePerUnit Decimal      @db.Decimal(10, 2)
  fixedCharge Decimal      @default(0) @db.Decimal(10, 2)
  total       Decimal      @db.Decimal(12, 2)
  dueDate     DateTime
  status      BillStatus   @default(ISSUED)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  payments    Payment[]    @relation("PaymentToWaterBill")
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit        Unit         @relation(fields: [unitId], references: [id], onDelete: Cascade)

  @@unique([unitId, period])
  @@index([orgId])
  @@index([tenantId, period])
  @@index([unitId, period])
  @@index([status])
  @@index([dueDate])
  @@index([orgId, status])
}

model TaxCharge {
  id               String       @id @default(cuid())
  orgId            String
  propertyId       String?
  leaseId          String?
  tenantId         String?
  taxType          TaxType
  taxAuthority     String       @default("KRA")
  taxAccountNumber String?
  period           String
  baseAmount       Decimal?     @db.Decimal(12, 2)
  taxRate          Decimal?     @db.Decimal(5, 2)
  amountDue        Decimal      @db.Decimal(12, 2)
  amountPaid       Decimal      @default(0) @db.Decimal(12, 2)
  balance          Decimal      @db.Decimal(12, 2)
  dueDate          DateTime
  status           TaxStatus    @default(PENDING)
  assessmentRef    String?
  kraPaymentRef    String?
  kraReceiptNo     String?
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  payments         Payment[]    @relation("PaymentToTaxCharge")
  lease            Lease?       @relation(fields: [leaseId], references: [id])
  org              Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  property         Property?    @relation(fields: [propertyId], references: [id])
  tenant           Tenant?      @relation(fields: [tenantId], references: [id])

  @@index([orgId])
  @@index([propertyId])
  @@index([leaseId])
  @@index([tenantId])
  @@index([taxType])
  @@index([status])
  @@index([dueDate])
  @@index([period])
}

model Payment {
  id                 String             @id @default(cuid())
  orgId              String
  payerTenantId      String
  method             PaymentMethod
  amount             Decimal            @db.Decimal(12, 2)
  reference          String?
  externalReference  String?
  targetType         PaymentTargetType
  rentChargeId       String?
  waterBillId        String?
  taxChargeId        String?
  gatewayStatus      GatewayStatus      @default(INITIATED)
  verificationStatus VerificationStatus @default(PENDING)
  checkoutRequestId  String?            @unique
  merchantRequestId  String?
  phoneUsed          String?
  callbackRaw        Json?
  paidAt             DateTime?
  notes              String?
  remittedToKra      Boolean            @default(false)
  remittedAt         DateTime?
  kraReference       String?
  kraReceiptNo       String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  org                Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  payerTenant        Tenant             @relation(fields: [payerTenantId], references: [id], onDelete: Cascade)
  rentCharge         RentCharge?        @relation("PaymentToRentCharge", fields: [rentChargeId], references: [id])
  taxCharge          TaxCharge?         @relation("PaymentToTaxCharge", fields: [taxChargeId], references: [id])
  waterBill          WaterBill?         @relation("PaymentToWaterBill", fields: [waterBillId], references: [id])
  receipt            Receipt?

  @@index([orgId, createdAt])
  @@index([payerTenantId, createdAt])
  @@index([gatewayStatus, verificationStatus])
  @@index([rentChargeId])
  @@index([waterBillId])
  @@index([taxChargeId])
  @@index([reference])
  @@index([externalReference])
  @@index([paidAt])
  @@index([remittedToKra, remittedAt])
  @@index([orgId, gatewayStatus, verificationStatus])
}

model Receipt {
  id        String   @id @default(cuid())
  paymentId String   @unique
  receiptNo String   @unique
  pdfUrl    String?
  issuedAt  DateTime @default(now())
  payment   Payment  @relation(fields: [paymentId], references: [id], onDelete: Cascade)
}

model Notification {
  id               String              @id @default(cuid())
  orgId            String
  userId           String?
  tenantId         String?
  channel          NotificationChannel
  type             NotificationType
  title            String
  message          String
  status           NotificationStatus  @default(QUEUED)
  providerResponse Json?
  sentAt           DateTime?
  readAt           DateTime?
  createdAt        DateTime            @default(now())
  org              Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant           Tenant?             @relation("NotificationTenant", fields: [tenantId], references: [id], onDelete: Cascade)
  user             User?               @relation("NotificationUser", fields: [userId], references: [id])

  @@index([orgId, createdAt])
  @@index([userId, createdAt])
  @@index([tenantId, createdAt])
  @@index([status, channel])
  @@index([type, createdAt])
  @@index([orgId, readAt])
}

model MoveOutNotice {
  id          String       @id @default(cuid())
  leaseId     String
  tenantId    String
  noticeDate  DateTime     @default(now())
  moveOutDate DateTime
  status      NoticeStatus @default(SUBMITTED)
  notes       String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  inspection  Inspection?
  lease       Lease        @relation(fields: [leaseId], references: [id], onDelete: Cascade)
  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([leaseId, status])
  @@index([tenantId, status])
  @@index([moveOutDate])
}

model Inspection {
  id              String           @id @default(cuid())
  noticeId        String           @unique
  scheduledAt     DateTime
  inspectorUserId String
  status          InspectionStatus @default(SCHEDULED)
  notes           String?
  checklist       Json?
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  inspector       User             @relation("InspectionInspector", fields: [inspectorUserId], references: [id])
  notice          MoveOutNotice    @relation(fields: [noticeId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
  @@index([status])
}

model IssueTicket {
  id               String         @id @default(cuid())
  orgId            String
  propertyId       String?
  unitId           String?
  reportedByUserId String
  assignedToUserId String?
  title            String
  description      String
  priority         TicketPriority @default(MEDIUM)
  status           TicketStatus   @default(OPEN)
  resolutionNotes  String?
  resolvedAt       DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  photoAssetId     String?
  assignedTo       User?          @relation("IssueAssignedTo", fields: [assignedToUserId], references: [id])
  org              Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
  photoAsset       Asset?         @relation("IssuePhoto", fields: [photoAssetId], references: [id])
  property         Property?      @relation(fields: [propertyId], references: [id])
  reportedBy       User           @relation("IssueReportedBy", fields: [reportedByUserId], references: [id])
  unit             Unit?          @relation(fields: [unitId], references: [id])

  @@index([orgId, status, priority])
  @@index([propertyId])
  @@index([unitId])
  @@index([reportedByUserId])
  @@index([assignedToUserId])
  @@index([resolvedAt])
}

model AuditLog {
  id          String       @id @default(cuid())
  orgId       String
  actorUserId String
  action      String
  entityType  String
  entityId    String
  metadata    Json?
  beforeState Json?
  afterState  Json?
  ip          String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime     @default(now())
  actor       User         @relation("AuditActor", fields: [actorUserId], references: [id])
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model TenantActionLog {
  id          String           @id @default(cuid())
  orgId       String
  tenantId    String
  leaseId     String?
  unitId      String?
  actorUserId String
  action      TenantActionType
  reason      String?
  notes       String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  actor       User             @relation("TenantActionActor", fields: [actorUserId], references: [id])
  lease       Lease?           @relation(fields: [leaseId], references: [id])
  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  unit        Unit?            @relation(fields: [unitId], references: [id])

  @@index([orgId, tenantId, createdAt])
  @@index([tenantId, createdAt])
  @@index([leaseId])
  @@index([unitId])
  @@index([actorUserId, createdAt])
  @@index([action, createdAt])
}

model Invitation {
  id          String       @id @default(cuid())
  orgId       String
  email       String
  role        OrgRole
  scopeType   ScopeType    @default(ORG)
  scopeId     String       @default("ORG_SCOPE")
  token       String       @unique
  expiresAt   DateTime
  status      String       @default("PENDING")
  invitedById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  invitedBy   User         @relation("InvitedBy", fields: [invitedById], references: [id])
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@index([usedAt])
}

model ApiKey {
  id          String       @id @default(cuid())
  orgId       String
  name        String
  keyHash     String
  lastUsedAt  DateTime?
  expiresAt   DateTime?
  permissions Json?
  isActive    Boolean      @default(true)
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   User         @relation("CreatedBy", fields: [createdById], references: [id])
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([isActive])
}

